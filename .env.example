# =========================================================
# OpenRouter
# =========================================================

LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=

OPENROUTER_MODEL=openai/gpt-4o-mini

# =========================================================
# LLM Limits
# =========================================================

DEFAULT_BATCH_SIZE_FILTER=5

DEFAULT_BATCH_SIZE_ANALYZE=5

OPENROUTER_MAX_TOKENS_FILTER=1000

OPENROUTER_MAX_TOKENS_ANALYZE=2000

OPENROUTER_MAX_TOKENS_SUMMARY=1500

MAX_REVIEW_CHARACTERS=800

# =========================================================
# Collection Defaults
# =========================================================

GOOGLE_PLAY_COUNTRY=us

GOOGLE_PLAY_LANGUAGE=en

REDDIT_USER_AGENT=spotify-discovery-research/0.1