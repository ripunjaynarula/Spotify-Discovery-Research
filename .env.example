# Required for LLM-powered filtering and analysis.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Required only when collecting Reddit reviews.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=spotify-discovery-research/0.1

# Optional collection defaults.
GOOGLE_PLAY_COUNTRY=us
GOOGLE_PLAY_LANGUAGE=en
